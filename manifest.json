{
  "manifest_version": 3,
  "name": "Open Passwords (v0.38)",
  "version": "0.38.0",
  "description": "Open-source client for Apple Passwords (iCloud Keychain) on Chrome. Connects to the macOS native helper and prompts for access.",
  "key": "",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Open Passwords"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "alarms",
    "privacy",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["*://*/*"]
    }
  ]
}